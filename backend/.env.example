# ── MindEase Environment Variables ──────────────────
# Copy this file to .env and fill in your values

# JWT Secret (change this to a long random string in production)
JWT_SECRET=mindease-super-secret-key-change-in-prod
JWT_EXPIRE_MINUTES=1440

# Firebase — Option A: path to credentials JSON file
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Firebase — Option B: paste the entire JSON as a single-line string
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Server
HOST=0.0.0.0
PORT=8000
